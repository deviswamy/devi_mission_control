{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"assist": {
		"enabled": true,
		"actions": { "source": { "organizeImports": "on" } }
	},
	"linter": {
		"enabled": true,
		"rules": { "recommended": true }
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"trailingCommas": "es5"
		}
	},
	"files": {
		"includes": [
			"apps/**",
			"packages/**",
			"!**/node_modules",
			"!**/dist",
			"!**/*.gen.ts",
			"!**/drizzle",
			"!**/.claude",
			"!**/*.css"
		]
	}
}
