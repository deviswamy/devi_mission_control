# Database
DATABASE_URL=postgres://user:password@localhost:5432/mission_control

# Auth0 — server (Hono)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.mission-control.dev
AUTH0_CLIENT_ID=your_m2m_client_id
AUTH0_CLIENT_SECRET=your_m2m_client_secret

# Auth0 — client (Vite exposes VITE_ prefix to browser)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_spa_client_id
VITE_AUTH0_AUDIENCE=https://api.mission-control.dev

# Server
PORT=3000

# Client (dev only — prod uses HTTPS URL of Railway service)
VITE_API_BASE_URL=http://localhost:3000

# CORS
CLIENT_ORIGIN=http://localhost:5173
